{
  "name": "lotto-number-generator",
  "version": "1.0.0",
  "description": "웹 기반 로또번호 추첨 애플리케이션",
  "private": true,
  "scripts": {
    "check-deps": "node scripts/check-deps.js",
    "pretest": "node scripts/check-deps.js",
    "preverify": "node scripts/check-deps.js",
    "test": "node --test test/test-logic.js && node test/test-dom.js",
    "test:logic": "node --test test/test-logic.js",
    "test:dom": "node test/test-dom.js",
    "test:dom:screenshot": "node test/test-dom.js --screenshot",
    "serve": "node scripts/serve.js",
    "verify": "node scripts/verify.js",
    "e2e:report": "node scripts/e2e-report.js",
    "verify:report": "node scripts/verify-report.js",
    "serve:temp": "node scripts/temp-server.js",
    "serve:cleanup": "node scripts/temp-server.js --cleanup",
    "prepare": "git config core.hooksPath scripts/hooks"
  },
  "devDependencies": {
    "puppeteer-core": "^24.0.0"
  }
}
